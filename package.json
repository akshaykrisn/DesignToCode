{
  "name": "skills-onboard",
  "displayName": "Skills Onboard",
  "description": "Guided onboarding to extract and configure AI agent skills and agent files into your repository.",
  "publisher": "akshay",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/akshay/skills-onboard.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillsOnboardContainer",
          "title": "Skills Onboard",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "skillsOnboardContainer": [
        {
          "type": "webview",
          "id": "skillsOnboard.homeView",
          "name": "Home"
        }
      ]
    },
    "commands": [
      {
        "command": "skillsOnboard.start",
        "title": "Skills Onboard: Start Onboarding"
      },
      {
        "command": "skillsOnboard.contribute",
        "title": "Skills Onboard: Contribute Skill Updates"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.3.0"
  }
}
